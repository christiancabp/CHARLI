// CHARLI Server — Database Schema
//
// Prisma 7: The `datasource` block only declares the provider.
// The connection URL lives in prisma.config.ts (for CLI) and
// src/prisma/prisma.service.ts (for runtime). Both read from DATABASE_URL.
//
// To switch to Postgres: change provider here, swap the driver adapter
// in prisma.service.ts and seed.ts, and update DATABASE_URL.

datasource db {
  provider = "sqlite"
}

// Prisma 7: generator outputs to a local directory (not node_modules).
// All source files import from '@prisma/generated' (tsconfig path alias
// pointing to prisma/generated/prisma/client/client).
generator client {
  provider = "prisma-client"
  output   = "./generated/prisma/client"
}

// ── Devices ─────────────────────────────────────────────────────────
// Each CHARLI device (desk hub, smart glasses, phone) gets a record here.
// The API key authenticates requests. System prompt customizes behavior.
//
// Naming convention:
//   name → kebab-case: "charli-home", "charli-glasses"
//   type → kebab-case: "desk-hub", "smart-glasses", "phone"

model Device {
  id           String   @id @default(uuid())
  name         String   @unique // "charli-home", "charli-glasses"
  type         String // "desk-hub", "smart-glasses", "phone"
  apiKey       String   @unique // For auth — sent in X-API-Key header. NEVER returned by GET /api/devices.
  systemPrompt String? // Custom prompt override (falls back to DEFAULT_PROMPTS[type] if null)
  maxTokens    Int      @default(150)
  lastSeen     DateTime?
  createdAt    DateTime @default(now())

  conversations Conversation[]
}

// ── Conversations ───────────────────────────────────────────────────
// One active conversation per device. Stores context for follow-up questions.

model Conversation {
  id        String   @id @default(uuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
}

// ── Messages ────────────────────────────────────────────────────────
// Individual messages within a conversation (user or assistant).
// Cascade delete: clearing a conversation removes all its messages.

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime     @default(now())
}
