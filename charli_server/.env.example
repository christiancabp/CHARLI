# CHARLI Server — Environment Variables
# Copy this to .env and fill in values

# OpenClaw gateway (runs on same Mac Mini)
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=your-token-from-openclaw.json

# Python ML sidecar (STT + TTS, runs alongside NestJS)
SIDECAR_URL=http://localhost:3001

# Server port
CHARLI_SERVER_PORT=3000

# Database (SQLite)
DATABASE_URL=file:./charli.db

# Admin API key for bootstrapping (creating first devices)
ADMIN_API_KEY=change-me-to-a-random-string
