# CHARLI Server — Environment Variables
# Copy this to .env and fill in values

# OpenClaw gateway (runs on same Mac Mini)
# Docker:     http://host.docker.internal:18789  (host machine from inside container)
# Bare-metal: http://localhost:18789
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=your-token-from-openclaw.json

# Python ML sidecar (STT + TTS, runs alongside NestJS)
# Docker:     http://sidecar:3001  (Docker Compose service name)
# Bare-metal: http://localhost:3001
SIDECAR_URL=http://localhost:3001

# Server port
CHARLI_SERVER_PORT=3000

# Database (SQLite via Prisma 7 driver adapter)
# Path is relative to the project root (charli_server/).
# This is read by BOTH prisma.config.ts (CLI) and prisma.service.ts (runtime).
# IMPORTANT: There should be only ONE charli.db file, at prisma/charli.db.
DATABASE_URL=file:./prisma/charli.db

# Admin API key for bootstrapping (creating first devices via POST /api/devices)
ADMIN_API_KEY=change-me-to-a-random-string
